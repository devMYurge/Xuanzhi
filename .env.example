# Xuanzhi — environment variables template.
#
# Copy this file to `.env` and fill in your keys:
#     cp .env.example .env
#
# `.env` is gitignored — keys never leave your machine.
# Neither key is strictly required; see SETUP.md §3 for what each unlocks.

# OpenAI — for --openai summarisation and the HF-vs-OpenAI comparison.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Semantic Scholar — optional; raises your API rate limit from the
# anonymous-tier default. Without it you'll occasionally hit 429s.
# Free key: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
